---
import { withBase } from "../lib/poems";

interface Props {
	current?: "home" | "write" | "poem";
}

const { current } = Astro.props;
const homeHref = withBase();
const writeHref = withBase("write/");
const showWritingNav = import.meta.env.DEV;
const githubHref = "https://github.com/Minsecrus/DrifterPoetry";
---

<header class="site-header">
	<a class="brand" href={homeHref}>DrifterPoetry</a>
	{
		showWritingNav && (
			<nav class="segmented-control site-nav" aria-label="Primary">
				<a class:list={["segment", { active: current === "home" || current === "poem" }]} href={homeHref}>Read</a>
				<a class:list={["segment", { active: current === "write" }]} href={writeHref}>Write</a>
			</nav>
		)
	}
	<div class="segmented-control theme-switcher" aria-label="Theme">
		<button class="segment" type="button" data-theme-choice="light">Light</button>
		<button class="segment" type="button" data-theme-choice="dark">Dark</button>
		<button class="segment" type="button" data-theme-choice="system">System</button>
	</div>
	<a class="github-link" href={githubHref} target="_blank" rel="noreferrer">GitHub</a>
</header>

<style>
	.site-header {
		display: grid;
		grid-template-columns: 1fr auto auto auto;
		align-items: center;
		gap: 20px;
		padding-bottom: var(--site-header-padding, 34px);
		border-bottom: 1px solid var(--line);
	}

	.brand {
		font-size: 0.88rem;
		color: var(--muted);
		text-decoration: none;
	}

	.brand:visited,
	.brand:hover {
		color: var(--muted);
	}

	.segmented-control {
		display: inline-flex;
		gap: 4px;
		align-items: center;
		padding: 3px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: var(--surface);
	}

	.segment {
		appearance: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 54px;
		height: 24px;
		border: 0;
		border-radius: 999px;
		padding: 0 10px;
		background: transparent;
		color: var(--muted);
		text-decoration: none;
		cursor: pointer;
		font: inherit;
		font-size: 0.78rem;
		line-height: 1;
	}

	.segment:hover,
	.segment.active,
	.segment.active:visited,
	.segment[aria-pressed="true"] {
		background: var(--accent-soft);
		color: var(--text);
	}

	.github-link,
	.github-link:visited {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 32px;
		border: 1px solid var(--line);
		border-radius: 999px;
		padding: 0 14px;
		background: var(--surface);
		color: var(--muted);
		text-decoration: none;
		font-size: 0.78rem;
		line-height: 1;
	}

	.github-link:hover {
		background: var(--accent-soft);
		color: var(--text);
	}

	@media (max-width: 720px) {
		.site-header {
			grid-template-columns: 1fr;
			align-items: start;
			padding-bottom: 28px;
		}
	}
</style>
